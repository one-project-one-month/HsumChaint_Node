generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}
enum UserType {
  Monk
  Donor
}
model User {
  id        Int     @id @default(autoincrement())
  phone     String  @unique
  username  String
  email     String?  @unique
  password  String  
  userType  UserType
  fcmToken  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isDeleted Boolean  @default(false)
}


