{
  "name": "hsumchaint_node",
  "module": "index.ts",
  "type": "module",
  "private": false,
  "license": "MIT",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --compile --minify --outfile dist/hsumchaint",
    "start": "./dist/hsumchaint",
    "db:migrate": "bun --env-file=.env prisma migrate dev",
    "db:migrate:prod": "bun --env-file=.env prisma migrate deploy",
    "db:seed": "bun --env-file=.env prisma/seed.ts",
    "db:studio": "bun --env-file=.env prisma studio",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "lint": "biome lint --write src/",
    "format": "biome format --write src/",
    "check": "biome check --write src/",
    "docker:dev": "docker-compose -f docker-compose-development.yml --env-file .env --profile dev up -d",
    "docker:staging": "docker-compose -f docker-compose-staging.yml --env-file .env --profile staging up -d",
    "docker:prod": "docker-compose -f docker-compose-production.yml --env-file .env --profile prod up -d",
    "docker:down": "docker-compose -f docker-compose-development.yml --env-file .env --profile dev down",
    "docker:down:staging": "docker-compose -f docker-compose-staging.yml --env-file .env --profile staging down",
    "docker:down:prod": "docker-compose -f docker-compose-production.yml --env-file .env --profile prod down"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@types/bun": "latest",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.3",
    "@types/swagger-stats": "^0.95.11",
    "lefthook": "^2.1.2",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.4.2",
    "swagger-stats": "^0.99.7"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@prisma/adapter-mariadb": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "consola": "^3.4.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dayjs": "^1.11.19",
    "dotenv": "^17.3.1",
    "es-toolkit": "^1.44.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mariadb": "^3.5.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.3.6",
    "zod-to-openapi": "^0.2.1"
  }
}
